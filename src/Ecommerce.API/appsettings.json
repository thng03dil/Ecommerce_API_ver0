{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Key": "",
    "Issuer": "EcommerceAPI",
    "Audience": "EcommerceUser",
    "ExpiryMinutes": 5,
    "RefreshTokenDays": 7
  },
  "Redis": {
    "ConnectionString": "",
    "InstanceName": "Ecommerce:",
    "DefaultExpirationMinutes": 5
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithProcessId"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "SystemLogs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 15,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss} [{Level:u3}] [{SourceContext}] {Message:lj} {Properties:j} {NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
