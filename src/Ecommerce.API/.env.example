# Copy to .env and fill in. ASP.NET Core maps double-underscore keys to nested config (Stripe:SecretKey).
Stripe__SecretKey=sk_test_your_key
Stripe__WebhookSecret=whsec_from_stripe_cli_or_dashboard
Stripe__PublishableKey=pk_test_your_key
Stripe__DefaultCurrency=usd

# Local webhook testing: install Stripe CLI, then:
#   stripe listen --forward-to https://localhost:<PORT>/api/stripe/webhook
# Use the "whsec_..." signing secret from CLI output as Stripe__WebhookSecret.
