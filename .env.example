# Đặt file này cạnh Ecommerce.sln, copy thành .env và điền giá trị.
# ASP.NET Core map dấu gạch dưới kép thành section (vd. Stripe__SecretKey -> Stripe:SecretKey).
# Docker Compose: docker-compose.yml đọc .env cùng thư mục để substitute ${Jwt__Key}...

Jwt__Key=your-jwt-signing-key-at-least-32-characters-long
AuthSecurity__FingerprintSecret=your-fingerprint-secret-32-chars-min
AuthSecurity__DeviceBindingSecret=your-device-binding-secret-32-chars-min

Stripe__SecretKey=sk_test_your_key
Stripe__WebhookSecret=whsec_from_stripe_cli_or_dashboard
Stripe__PublishableKey=pk_test_your_key
Stripe__DefaultCurrency=vnd
Stripe__SuccessUrl=https://localhost:7035/checkout/success?session_id={CHECKOUT_SESSION_ID}
Stripe__CancelUrl=https://localhost:7035/checkout/cancel

# Webhook local: stripe listen --forward-to https://localhost:<PORT>/api/stripe/webhook
